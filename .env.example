# MediCopilot — environment variables
#
# Canonical list of every env var across phases P0→P5.
# Fill in values for your current phase; leave future-phase vars empty.
# NEVER commit a real .env file — only this .env.example stays in git.
#
# Naming convention:
#   VITE_*   — client-visible (exposed in the browser bundle). Never put secrets here.
#   Everything else — server-only. Secrets live here.

# ───────────────────────────────────────────
# Client-visible (safe to ship to browser)
# ───────────────────────────────────────────
VITE_APP_ENV=development           # development | preview | production
VITE_APP_URL=http://localhost:5173
VITE_POSTHOG_KEY=                  # P2+ — PostHog project key (public, writable only)
VITE_POSTHOG_HOST=                 # P2+ — self-hosted PostHog URL
VITE_SENTRY_DSN=                   # P1+ — Sentry DSN (frontend)

# ───────────────────────────────────────────
# P1 — OCR / Vision (server-only secrets)
# ───────────────────────────────────────────
ANTHROPIC_API_KEY=                 # Claude API key — Sonnet 4.6 + Haiku 4.5

# ───────────────────────────────────────────
# P2 — Backend, Transcription, Database, Auth
# ───────────────────────────────────────────
# Deepgram streaming STT
DEEPGRAM_API_KEY=

# Neon Postgres (primary data store from MVP)
DATABASE_URL=                      # postgresql://... (Neon connection string)

# Upstash Redis (transcript window, OTP rate limits, session state)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Twilio Verify (SMS-OTP auth)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=         # from https://console.twilio.com/us1/develop/verify/services

# JWT signing (HS256) — generate with `openssl rand -base64 64`
JWT_SECRET=
JWT_ISSUER=medicopilot
JWT_AUDIENCE=medicopilot-web

# Backend URL (client talks to this over WSS)
VITE_BACKEND_WSS_URL=              # wss://... e.g. wss://medicopilot-api.fly.dev/stream

# Observability (server-side)
SENTRY_DSN=                        # backend Sentry DSN
AXIOM_TOKEN=                       # Axiom ingest token
AXIOM_DATASET=medicopilot

# ───────────────────────────────────────────
# P3 — Twilio telephony demo + Retell AI
# ───────────────────────────────────────────
TWILIO_PHONE_NUMBER=               # demo DID, E.164 format
RETELL_API_KEY=
RETELL_AGENT_ID=                   # the Maria-Garcia demo agent

# ───────────────────────────────────────────
# P4 — macOS native wrapper (Tauri)
# ───────────────────────────────────────────
APPLE_DEVELOPER_ID=                # for notarization
APPLE_NOTARIZE_USER=
APPLE_NOTARIZE_APP_PASSWORD=       # app-specific password from appleid.apple.com
APPLE_TEAM_ID=

# ───────────────────────────────────────────
# P5 — Multi-tenancy, Billing, HIPAA
# ───────────────────────────────────────────
# Clerk Organizations (replaces Twilio-Verify-only auth at P5)
CLERK_PUBLISHABLE_KEY=             # VITE_CLERK_PUBLISHABLE_KEY for client
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=              # price_... for $49/seat/mo
STRIPE_PRICE_ANNUAL=               # price_... for $39/seat/mo

# S3 (transcripts + audit log archive)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_TRANSCRIPTS=

# CMS data sources (Plan Provider — activated post-MVP)
CMS_MARKETPLACE_API_TOKEN=         # request at https://developer.cms.gov/
