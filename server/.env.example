# MediCopilot server — environment variables
#
# Copy to `.env` and fill in. Never commit `.env`.
# The root `.env.example` is the canonical list across the whole product;
# this file is the server-specific subset (DEEPGRAM_API_KEY etc).

# ── Tier 1 (basic Fastify boot) ─────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
APP_VERSION=0.1.0-dev
CORS_ORIGIN=*

# ── Tier 2 (live audio pipeline) ────────────────────────────
# Deepgram Nova-3 streaming. Without this set, WSS /stream will
# accept connections but reject `start` with `{code:"no_api_key"}`.
# Get a key at https://deepgram.com (free tier covers MVP dogfood).
# In prod: `fly secrets set DEEPGRAM_API_KEY=...`
DEEPGRAM_API_KEY=
DEEPGRAM_SAMPLE_RATE=16000

# ── Tier 3 (Claude suggestion engine) ───────────────────────
# Anthropic API key for Haiku 4.5 suggestion calls. Without this,
# WSS /stream will still ship transcripts but no suggestion frames.
ANTHROPIC_API_KEY=
# Override defaults if you want to dogfood on a different model or
# tune the cooldown / context window.
SUGGESTION_MODEL=claude-haiku-4-5-20251001
SUGGESTION_DEBOUNCE_MS=4000
SUGGESTION_WINDOW_MS=120000
